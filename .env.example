# ─────────────────────────────────────────────────────────────────────────────
# PerfilaPro — Variables de entorno
# Copia este archivo como .env.local para desarrollo local.
# NUNCA subas .env.local al repositorio.
# Los valores reales se gestionan en Netlify → Site settings → Environment.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Dashboard: https://supabase.com/dashboard/project/<id>/settings/api

# URL del proyecto (pública, no es un secreto)
SUPABASE_URL=https://<project-ref>.supabase.co

# Llave service_role — CRÍTICA. Acceso total a la BD sin RLS.
# Nunca exponer en frontend ni en logs.
SUPABASE_SERVICE_KEY=eyJ...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com/apikeys
# Usar sk_test_... / whsec_test_... en dev y preview. Nunca sk_live en local.

# Llave secreta — CRÍTICA.
STRIPE_SECRET_KEY=sk_live_...

# Secreto de firma del webhook (Developers → Webhooks → tu endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# IDs de precio (Products → tu producto → Pricing)
STRIPE_PRICE_BASE=price_...
STRIPE_PRICE_PRO=price_...

# Sprint 3 · Stripe Subscription (modelo recurrente). No usados todavia,
# se rellenan cuando se recreen los productos en Stripe live como recurrentes.
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# ── Stripe Subscription B2B (Sprint Bloque A — orgs por seats) ───────────────
# 4 prices recurrentes, uno por tier × ciclo. Cada price es €/profesional/mes
# (seat-based) y el endpoint `create-org-checkout` multiplica por seats via
# Stripe quantity. Si alguno queda vacio, la landing /es/empresas captura el
# lead pero el checkout devuelve 503 — util para activar el carril por tiers
# parcialmente (ej. solo Team mientras se cierra el pricing de Org).
# Tier Enterprise no tiene price recurrente: el CTA cae al form lead-b2b.
STRIPE_PRICE_TEAM_MONTHLY=price_...
STRIPE_PRICE_TEAM_ANNUAL=price_...
STRIPE_PRICE_ORG_MONTHLY=price_...
STRIPE_PRICE_ORG_ANNUAL=price_...

# ── Resend ────────────────────────────────────────────────────────────────────
# Dashboard: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Gemini (Google AI Studio) ─────────────────────────────────────────────────
# Dashboard: https://aistudio.google.com/apikey
# Usado por:
#   - scripts/generate-seeds.js  (regeneración de las 75 imágenes seed
#                                 con gemini-2.5-flash-image)
#   - netlify/functions/lab-gemini.js  (endpoint interno de prompts)
GEMINI_API_KEY=

# ── Admin panel ───────────────────────────────────────────────────────────────
# Contraseña para /admin.html — mínimo 20 caracteres aleatorios
# Generar: openssl rand -base64 24
ADMIN_PASSWORD=

# Semilla TOTP para 2FA del admin (opcional — si no se define, 2FA desactivado)
# Generar: openssl rand -base64 20 | base32
ADMIN_TOTP_SECRET=

# Secreto para firmar la sesión JWT del admin (se intercambia por password+TOTP
# para no re-pedir el código de 30s a mitad de un flujo largo). Si no se define,
# cae a AGENT_JWT_SECRET. Generar: openssl rand -base64 32
ADMIN_JWT_SECRET=

# TTL de la sesión admin en minutos (opcional, default 60, mínimo 5).
ADMIN_SESSION_TTL_MINUTES=60

# ── Agentes comerciales ───────────────────────────────────────────────────────
# Secreto para firmar JWT de agentes (HS256, TTL 7 días)
# Generar: openssl rand -base64 32
AGENT_JWT_SECRET=

# ── Panel cliente B2B self-serve ──────────────────────────────────────────────
# Secreto para firmar JWT de panel B2B (HS256, TTL 7 días). Si no se define,
# cae a AGENT_JWT_SECRET. Tener una env propia permite rotar uno sin el otro.
# Generar: openssl rand -base64 32
ORG_PANEL_JWT_SECRET=

# ── Landing B2B (/es/empresas, /ca/empresas) ─────────────────────────────────
# Email que recibe los leads del formulario de empresas. Si no se define,
# el endpoint lead-b2b devuelve 500. Ej: leads@perfilapro.es
B2B_LEAD_INBOX=

# ── PostHog (observabilidad / analytics) ─────────────────────────────────────
# Project API key (public). Visible en frontend cuando el usuario acepta
# cookies en el banner de privacidad. Si no esta definida, la analitica
# queda deshabilitada silenciosamente (no se carga PostHog ni se emiten
# eventos server-side). Dashboard: https://eu.posthog.com (region EU).
POSTHOG_API_KEY=
POSTHOG_HOST=https://eu.i.posthog.com

# ── Promo de lanzamiento (acción comercial 100% bonificada) ─────────────────
# Cuando vale "1", el editor reemplaza el flujo de Stripe por una activación
# directa: el usuario pulsa "Activar gratis · Promo lanzamiento", el backend
# pasa el plan de Free → Base/Pro durante 90/365 días, genera el kit y manda
# un Comprobante de Promoción por email (NO factura — bonificación 100% sin
# contraprestación, fuera de Verifactu). Cualquier otro valor (vacío, "0")
# desactiva la promo y restituye el checkout normal de Stripe.
LAUNCH_PROMO_ACTIVE=

# ── Funnels de activación gratuita (wedge B2C → B2B) ─────────────────────────
# Cuando valen "1", register-free activa la card como Pro gratis tras el alta
# (sustituye el welcome email por el demo email con tarjeta A6). Reversibles:
# borrar la env var restituye el carril de pago. Cualquier otro valor = off.
#   - DEMO_FUNNEL_FREE_ACTIVE: solo altas con ?via=demo-* (campaña dirigida).
#   - WEB_FUNNEL_FREE_ACTIVE:  TODA alta orgánica entra como Pro (Stripe dormido).
DEMO_FUNNEL_FREE_ACTIVE=
WEB_FUNNEL_FREE_ACTIVE=

# ── Quipu (facturación legal Verifactu/AEAT) ─────────────────────────────────
# Sprint 3. No usadas todavia. El cliente lib/quipu-client.js es skeleton
# hasta que la validacion tecnica del proveedor concluya y se firme.
# Dashboard: https://getquipu.com  → Configuracion → API
QUIPU_CLIENT_ID=
QUIPU_CLIENT_SECRET=
QUIPU_API_BASE=https://getquipu.com/api/v2
QUIPU_ENV=sandbox

# ── Cantera (vertical deporte base) ───────────────────────────────────────────
# Todas opcionales — el carril se apaga limpio borrándolas. Sin
# CANTERA_VERTICAL_ACTIVE, todos los endpoints del carril devuelven 410 Gone.

# "1" enciende el carril Cantera. Cualquier otro valor lo apaga.
CANTERA_VERTICAL_ACTIVE=

# Clave AES-256-GCM (32 bytes hex) para cifrar birth_date_encrypted app-side
# (lib/pii-crypto.js). Generar: openssl rand -hex 32
# OJO: si no se define, la fecha de nacimiento se guarda solo como birth_year
# en claro (degradación de PII). NO rotar con datos ya cifrados sin re-cifrar.
CANTERA_PII_KEY=

# Secreto para firmar el JWT del panel del padre/tutor (parent-panel).
# Si no se define, cae a ORG_PANEL_JWT_SECRET → AGENT_JWT_SECRET.
# Generar: openssl rand -base64 32
PARENT_PANEL_JWT_SECRET=

# Secreto de firma separado para eventos Stripe Connect (cuotas direct-charge
# desde cuentas conectadas de clubes). El webhook prueba primero
# STRIPE_WEBHOOK_SECRET y cae a este.
STRIPE_CONNECT_WEBHOOK_SECRET=

# Comisión de la plataforma sobre la cuota padre→club, en basis points.
# Default 0 (sin application_fee). Ej: 250 = 2,5%.
STRIPE_PLATFORM_FEE_BPS=

# Stripe Price IDs del carnet físico PVC+NFC (cobro directo a plataforma).
STRIPE_PRICE_PLAYER_SETUP_FEE=price_...
STRIPE_PRICE_PLAYER_RENEWAL=price_...

# Sprint 2 / aún no cableadas en código (documentadas para referencia):
#   STRIPE_PRICE_PARENT_PREMIUM   — 4-6€/mes premium padre
#   STRIPE_PRICE_CARD_MAINTENANCE — 1€/mes mantenimiento entre clubes
#   PRINT_PROVIDER                — 'manual' (founder exporta CSV) | proveedor
#   PRINT_PROVIDER_API_KEY        — solo si PRINT_PROVIDER != 'manual'

# ── INMO · rastreo de subastas (costa de Tarragona) ──────────────────────────
# Vertical independiente (entidad propia `subastas`, NO sobrecarga `cards`).
# Gateado: con cualquier valor != '1' el carril queda dormido (cron no hace
# nada, /s/:slug devuelve 404). Ver docs/inmo-subastas.md.
#   INMO_VERTICAL_ACTIVE  — '1' enciende el carril.
#   INMO_ALERT_INBOX      — email que recibe el aviso diario (nuevas + cierran pronto).
#   INMO_BOE_SEARCH_URL   — URL de búsqueda del Portal de Subastas ya filtrada por
#                           Provincia=Tarragona + Tipo=Inmuebles. Lo más fiable es
#                           copiarla del navegador tras aplicar los filtros. Si se
#                           omite, se usa un default (provincia 43 / inmuebles).
#   INMO_MAX_PAGES        — nº máx de páginas de listado a recorrer. Default 5.
#   INMO_REQUEST_DELAY_MS — pausa entre peticiones al BOE (cortesía). Default 800.
INMO_VERTICAL_ACTIVE=
INMO_ALERT_INBOX=
INMO_BOE_SEARCH_URL=
INMO_MAX_PAGES=5
INMO_REQUEST_DELAY_MS=800

# ── General ───────────────────────────────────────────────────────────────────
# URL pública del sitio — sin barra final
SITE_URL=https://perfilapro.es
# Netlify también inyecta `URL` automáticamente en cada deploy.
